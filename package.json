{
  "name": "johannes",
  "private": true,
  "license": "GPL-3.0",
  "type": "module",
  "scripts": {
    "postinstall": "lex install --ci",
    "lex:update": "lex install --update --save",
    "lex:build": "lex build --clear --lexicons ./lexicons --out ./src/lexicons",
    "predev": "pnpm run lex:build",
    "prebuild": "pnpm run lex:build",
    "pretest": "pnpm run lex:build",
    "pretype-check": "pnpm run lex:build",
    "dev": "astro dev",
    "build": "astro build",
    "deploy": "wrangler deploy",
    "preview": "wrangler dev",
    "types": "wrangler types",
    "test": "vitest",
    "type-check": "astro check && tsc",
    "lint": "biome lint .",
    "lint:fix": "biome lint --write .",
    "format": "biome format .",
    "format:fix": "biome format --write .",
    "check": "biome check .",
    "check:fix": "biome check --write ."
  },
  "packageManager": "pnpm@11.3.0",
  "engines": {
    "node": "26.2.0",
    "pnpm": "11"
  },
  "dependencies": {
    "@astrojs/check": "0.9.9",
    "@astrojs/cloudflare": "13.5.4",
    "@astrojs/sitemap": "3.7.2",
    "@atproto/lex": "0.1.2",
    "@atproto/lex-password-session": "0.1.0",
    "@tailwindcss/vite": "4.3.0",
    "astro": "6.3.7",
    "tailwindcss": "4.3.0"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.15",
    "@types/node": "24.12.4",
    "typescript": "6.0.3",
    "vitest": "4.1.7",
    "wrangler": "4.94.0"
  }
}
